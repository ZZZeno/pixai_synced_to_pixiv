{
  "manifest_version": 3,
  "name": "PixAI → Pixiv / 𝕏 Publisher",
  "version": "1.1.0",
  "description": "PixAIの作品をワンクリックでPixiv・𝕏に同期投稿",
  "permissions": [
    "storage",
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "https://pixai.art/*",
    "https://www.pixiv.net/*",
    "https://*.cloudfront.net/*",
    "https://*.pixai.art/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://pixai.art/artwork/*", "https://pixai.art/*/artwork/*", "https://www.pixai.art/artwork/*", "https://www.pixai.art/*/artwork/*"],
      "js": ["pixai-content.js"],
      "css": ["pixai-content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.pixiv.net/illustration/create*",
        "https://www.pixiv.net/manga/create*"
      ],
      "js": ["pixiv-content.js"],
      "css": ["pixiv-content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://x.com/compose/*",
        "https://x.com/intent/tweet*",
        "https://twitter.com/compose/*",
        "https://twitter.com/intent/tweet*",
        "https://x.com/home*",
        "https://x.com/*"
      ],
      "js": ["twitter-content.js"],
      "css": ["twitter-content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
